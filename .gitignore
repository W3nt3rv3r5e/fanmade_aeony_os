# =============================================
# AeonyOS: Zenith - .gitignore
# Conceptual browser-based desktop environment
# =============================================

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Editor / IDE files
.vscode/
.idea/
*.swp
*.swo
*~
.project
.settings/
*.sublime-*

# Logs and temporary files
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Runtime or cache
.cache/
.tmp/
temp/

# If you ever add testing or build folders later
/dist/
/build/
/out/

# Environment variables (in case you add any later)
.env
.env.local
.env.*.local

# Node.js (in case you add any tools later)
node_modules/
package-lock.json
yarn.lock
pnpm-lock.yaml

# Backup files
*.bak
*.backup

# Custom cursor or large generated assets (if any)
# (keep only what you intentionally version)
# *.svg   <- Do NOT uncomment if you want to keep cursor.svg

# =============================================
# AeonyOS specific notes:
# We intentionally track:
#   - index.html
#   - style.css
#   - script.js
#   - assets/, components/, src/components/
#   - cursor.svg
# =============================================
